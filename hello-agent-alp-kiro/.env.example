GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
PORT=8000

# Knowledge base — semantic search (uses same GEMINI_API_KEY, no extra key needed)
# Embedding model is set in server.py: models/gemini-embedding-001

# Web search — Serper Google Search API (free tier: 2,500 queries, no credit card)
# Get your key at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Supabase — pgvector knowledge database
# Create a free project at: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Groq — Whisper transcription API (free at console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Set to true on first run to seed the knowledge DB from knowledge/alp-docs.json
SEED_KNOWLEDGE_DB=false
